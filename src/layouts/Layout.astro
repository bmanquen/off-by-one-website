---
import '../styles/global.css';
import TopBar from '../components/TopBar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  dark?: boolean;
}

const {
  title,
  description = 'Off By One Labs — an independent software studio building indie products and selective contract work for teams that ship.',
  dark = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700;800&family=Instrument+Serif:ital@1&family=Geist+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class={dark ? 'dark' : ''}>
    <div class="grain" aria-hidden="true"></div>
    <TopBar dark={dark} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
