---
interface Props {
  dark?: boolean;
}

const { dark = false } = Astro.props;

const navLinks = [
  { href: '/products', label: 'Products' },
  { href: '/contact', label: 'Contact' },
];
---

<header
  class:list={[
    'sticky top-0 z-50 w-full border-b',
    dark
      ? 'bg-ink text-paper border-paper/20'
      : 'bg-paper text-ink border-rule',
  ]}
>
  <div class="mx-auto flex h-16 max-w-[1280px] items-center justify-between px-[22px] md:px-8">
    <a href="/" class="text-base font-bold tracking-[-0.02em]">
      Off By <em class="font-serif italic text-accent">One</em> Labs
    </a>
    <nav class="hidden items-center gap-8 font-mono text-[12px] uppercase tracking-[0.1em] md:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="py-2 transition-colors hover:text-accent"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
